FROM node:22-slim

WORKDIR /app

RUN npm install -g pnpm@9

COPY . .

RUN pnpm install --no-frozen-lockfile

ENV PORT=3000
ENV BASE_PATH=/

RUN pnpm --filter @workspace/dowry-africa build

WORKDIR /app/artifacts/dowry-africa

EXPOSE 3000

CMD ["pnpm", "run", "preview", "--host", "0.0.0.0", "--port", "3000"]
