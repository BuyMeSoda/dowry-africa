FROM node:18-alpine

WORKDIR /app

RUN npm install -g pnpm@9

COPY pnpm-workspace.yaml ./
COPY package.json ./
COPY pnpm-lock.yaml ./

COPY artifacts/ ./artifacts/
COPY lib/ ./lib/

RUN pnpm install --no-frozen-lockfile

RUN pnpm --filter @workspace/dowry-africa build

WORKDIR /app/artifacts/dowry-africa

EXPOSE 3000

CMD ["pnpm", "run", "preview", "--host", "0.0.0.0", "--port", "3000"]
